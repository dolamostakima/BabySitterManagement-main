<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Kido Haven</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        body {
            background: #fff7fb;
            color: #374151;
            font-family: 'Segoe UI', sans-serif;
        }

        /* Navbar */
        .navbar {
            background: #DBBEB6; 
            overflow: visible !important;
        }

       

        /* All buttons rounded */
        .btn {
            border-radius: 30px !important;
            padding: 6px 18px;
        }

        /* Primary button */
        .btn-primary {
            background: #f472b6;
            border: none;
        }

            .btn-primary:hover {
                background: #ec4899;
            }

        /* Outline button */
        .btn-outline-light {
            border: 1.5px solid white;
        }

        /* Search button */
        .search-btn {
            border: none;
            background: #f472b6;
            width: 34px;
            height: 34px;
            border-radius: 50%;
            color: white;
        }

            .search-btn:hover {
                background: #ec4899;
            }

        /* Card */
        .sitter-card {
            border-radius: 20px;
            background: white;
            transition: 0.3s;
        }

            .sitter-card:hover {
                transform: translateY(-6px);
            }

        /* Text highlight */
        .highlight {
            color: #fb7185;
        }

        /* Soft section background */
        .soft-box {
            background: #fdf2f8;
            border-radius: 20px;
            padding: 20px;
        }

        .btn:hover {
            transform: translateY(-2px);
            transition: 0.3s;
        }

        .brand-text {
            font-size: 22px;
            font-weight: 700;
            letter-spacing: 1px;
            /* Gradient text like image */
           /*  background: linear-gradient(135deg, #C85A5A, #E98B8B); */
            
           /*  -webkit-text-fill-color: transparent; */
            text-shadow: 0px 1px 1px rgba(0,0,0,0.1);
        }

        .dropdown-menu {
            position: absolute;
            right: auto;
            left: auto;
            transform: translateX(-80%); /* 🔥 main fix */
            z-index: 9999;
            min-width: 220px;
        }
        .container-fluid {
            overflow: visible !important;
        }

    </style>
</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-dark ">
        <div class="container-fluid">

            <a class="navbar-brand d-flex align-items-center" href="/">
                <img src="~/images/logo__2_-removebg-preview.png" width="100" class="me-2" />
                
            </a>
            

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMenu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarMenu">

                

                <form id="searchForm" class="d-flex position-relative " style="width:250px;">
                    <input class="form-control rounded-pill pe-5"
                           type="search"
                           id="searchInput"
                           placeholder="Search sitter by Location ..." />

                    <button type="submit" class="position-absolute end-0 top-50 translate-middle-y me-2 search-btn">
                        <i class="bi bi-search"></i>
                    </button>
                </form>



                <ul class="navbar-nav ms-auto align-items-center" id="authNavMenu">
                </ul>
               

            </div>
            <ul class="navbar-nav me-auto mb-2 mb-lg-0" id="dynamicNavMenu">
            </ul>
        </div>
    </nav>

    <div class="content">
        <main class="container my-4">
            <div id="result"></div>
            @RenderBody()

        </main>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // ---------------- Config ----------------
        const API_BASE = "";
        function getToken() { return localStorage.getItem("jwt_token"); }
        function setToken(t) { localStorage.setItem("jwt_token", t); }
        function getRoles() {
          try { return JSON.parse(localStorage.getItem("user_roles") || "[]"); }
          catch { return []; }
        }
        function isLoggedIn() { return !!getToken(); }
        function hasRole(role) { return getRoles().includes(role); }

        function logout() {
          localStorage.removeItem("jwt_token");
          localStorage.removeItem("user_roles");
          localStorage.removeItem("user_email");
          location.href = "/Web/Login";
        }

        // JWT attach for all ajax
        $.ajaxSetup({
          beforeSend: function(xhr){
            const t = getToken();
            if(t) xhr.setRequestHeader("Authorization", "Bearer " + t);
          }
        });

        // ---------------- Menu Definitions ----------------
        const MENU = {
          parent: [
            // { text:"Home", url:"/Web/Index" },
            { text:"Dashboard", url:"/Web/ParentDashboard" },
            { text:"BookingRequest", url:"/Web/Sitters" },
            { text:"My Bookings", url:"/Web/ParentBookings" },
           { text:"Payment", url:"/ParentPayment/ParentPayment" },
            { text:"My Reviews", url:"/Web/MyReviews" },
            { text:"Favorites", url:"/Web/Favorites" },
           { text:"🕭", url:"/Web/Notifications", type:"icon" }
          ],
          sitter: [
            // { text:"Home", url:"/Web/Index" },
            { text:"Dashboard", url:"/Web/SitterDashboard" },
            { text:"My Profile", url:"/Web/SitterProfile" },
            { text:"Availability", url:"/Web/SitterAvailability" },
            { text:"Bookings", url:"/Web/SitterBookings" },
           { text:"🕭", url:"/Web/Notifications", type:"icon" }
          ],
          admin: [
            // { text:"Home", url:"/Web/Index" },
            { text:"Dashboard", url:"/Web/AdminDashboard" },
            { text:"Approval", url:"/Web/AdminSitters" },
            { text:"Bookings", url:"/Web/AdminBookings" },
            { text:"Users", url:"/Web/AdminUsers" },
            { text:"Payments", url:"/Web/AdminPayments" },
            { text:"Reviews", url:"/Web/AdminReviews" },
          ]
        };




        // ---------------- Render Navbar Dynamically ----------------
        function renderNavbar() {
          const path = location.pathname.toLowerCase();
          const logged = isLoggedIn();

          let roleItems = [];
          let authHtml = "";

          // Not logged in (Guest)
                 if (!logged) {
            roleItems = []; // left side empty

            authHtml = `
                <li class="nav-item me-2">
                    <a class="nav-link text-white fw-semibold" href="/Web/Index">Home</a>
                </li>
                <li class="nav-item me-2">
                    <a class="btn btn-outline-light" href="/Web/Login">Login</a>
                </li>
                <li class="nav-item">
                    <a class="btn btn-outline-light " href="/Web/Register">Register</a>
                </li>
            `;
        }

          // Logged in
          else {
            const roles = getRoles();
            const userEmail = localStorage.getItem("user_email") || "User";

            if (roles.includes("Admin")) roleItems = MENU.admin;
            else if (roles.includes("BabySitter")) roleItems = MENU.sitter;
            else roleItems = MENU.parent;

         
          }

          // Build Menu Links
          let menuHtml = "";
          roleItems.forEach(x => {

            const active = path === x.url.toLowerCase() ? "active" : "";

            let sizeClass = x.type === "icon" ? "fs-3" : "fs-5";

            menuHtml += `<li class="nav-item"><a class="nav-link fs-5  ${active}" href="${x.url}">${x.text}</a></li>`;
          });
                  // Profile icon left side (after menu)
        if (logged) {
            const roles = getRoles();
            const userEmail = localStorage.getItem("user_email") || "User";

            menuHtml += `
                <li class="nav-item dropdown ms-2">
                    <a class="nav-link" href="#" role="button" data-bs-toggle="dropdown">
                        <i class="bi bi-person-circle fs-4"></i>
                    </a>

                    <ul class="dropdown-menu shadow">
                        <li class="px-3 py-2 text-center">
                            <strong>${userEmail}</strong><br>
                            <small class="text-muted">${roles[0]}</small>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <button class="dropdown-item text-danger" onclick="logout()">
                                Logout
                            </button>
                        </li>
                    </ul>
                </li>
            `;
        }

          $("#dynamicNavMenu").html(menuHtml);
          $("#authNavMenu").html(authHtml);
        }

        // ---------------- Page Guard (role required) ----------------
        const PAGE_RULES = [
          { prefix: "/web/admindashboard", roles: ["Admin"] },
          { prefix: "/web/adminsitters", roles: ["Admin"] },
          { prefix: "/web/adminbookings", roles: ["Admin"] },
          { prefix: "/web/adminusers", roles: ["Admin"] },
          { prefix: "/web/adminpayments", roles: ["Admin"] },

          { prefix: "/web/parentbookings", roles: ["Parent"] },
          { prefix: "/web/favorites", roles: ["Parent"] },

          { prefix: "/web/sitterbookings", roles: ["BabySitter"] },
          { prefix: "/web/sitterprofile", roles: ["BabySitter"] },
          { prefix: "/web/sitteravailability", roles: ["BabySitter"] }
        ];

        function enforcePageRules(){
          const path = location.pathname.toLowerCase();
          const rule = PAGE_RULES.find(r => path.startsWith(r.prefix));
          if(!rule) return;

          if(!isLoggedIn()){
            location.href = "/Web/Login";
            return;
          }

          const roles = getRoles();
          const ok = rule.roles.some(rr => roles.includes(rr));
          if(!ok){
            location.href = "/Web/Index";
          }
        }

        // Initialize
        renderNavbar();
        enforcePageRules();

        function showMsg(selector, msg, type) {
            const cls = type === "ok" ? "alert-success" : "alert-danger";
            $(selector).html(`<div class="alert ${cls}">${msg}</div>`);
        }

            $("#searchForm").submit(function (e) {
            e.preventDefault();

            let query = $("#searchInput").val();

            $.ajax({
                url: "/api/Sitters/search",
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify({
                    locationText: query
                }),
                success: function (res) {
                    console.log(res);
                   render(res.items || []);
                },
                error: function () {
                    alert("Search failed ❌");
                }
            });

        });

        function render(items) {
            if (!items.length) {
                $("#result").html(`<div class="alert alert-warning">No sitters found.</div>`);
                return;
            }

            let html = `<div class="row g-3">`;
            items.forEach(s => {
                html += `
                  <div class="col-md-4">
                    <div class="card p-3 h-100">
                      <h5>${s.fullName}</h5>
                      <div>Rate: <b>${s.hourlyRate}</b></div>
                      <div>Exp: ${s.experienceYears} years</div>
                      <div>Location: ${s.locationText}</div>
                      <div>Rating: ${s.avgRating} (${s.reviewCount})</div>
                      <a class="btn btn-sm btn-outline-primary mt-2" href="/Web/SitterDetails/${s.babySitterProfileId}">Details & Booking</a>
                    </div>
                  </div>`;
            });
            html += `</div>`;
            $("#result").html(html);
        }

    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>