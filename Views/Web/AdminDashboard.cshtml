@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">

    <!-- ✅ Top Stats Cards -->
    <div class="row g-4 mb-4">

        <div class="col-md-3">
            <div class="card shadow-sm p-3 text-center">
                <h6>Total Users</h6>
                <h3 class="text-primary">120</h3>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm p-3 text-center">
                <h6>Total Bookings</h6>
                <h3 class="text-success">85</h3>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm p-3 text-center">
                <h6>Active Sitters</h6>
                <h3 class="text-warning">32</h3>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm p-3 text-center">
                <h6>Notifications</h6>
                <h3 class="text-danger">5</h3>
            </div>
        </div>

    </div>

    <!-- ✅ Search Sitter -->
    <div class="card shadow-sm p-4 mb-4">
        <h5>Search Sitter</h5>

        <div class="input-group mt-2">
            <input type="text" class="form-control" placeholder="Search by name, location..." />
            <button class="btn btn-primary">Search</button>
        </div>
    </div>

    <!-- ✅ Notification Panel + Map -->
    <div class="row g-4">

        <!-- Notifications -->
        <div class="col-md-4">
            <div class="card shadow-sm p-3">
                <h5>Notifications</h5>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item">New sitter registered</li>
                    <li class="list-group-item">New booking received</li>
                    <li class="list-group-item">User updated profile</li>
                </ul>
            </div>
        </div>

        <!-- Google Map -->
        <div class="col-md-8">
            <div class="card shadow-sm p-3">
                <h5>Live Location</h5>

                <iframe src="https://www.google.com/maps?q=Dhaka&output=embed"
                        width="100%"
                        height="350"
                        style="border:0;">
                </iframe>

            </div>
        </div>

    </div>

</div>