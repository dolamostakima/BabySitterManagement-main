@{
    ViewData["Title"] = "Home ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - SmartBabySitter</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">



        <style>
        body {
            background: linear-gradient(135deg, #F9E3DF, #F3C6C0);
        }
        </style>
    </head>

    <body>
    <div class="container py-5">

        <div class="row align-items-center g-4 mb-5">
            <div class="col-lg-6">
                <div class="pe-lg-4">
                    <span class="badge bg-primary-subtle text-primary px-3 py-2 rounded-pill mb-3">
                        Trusted Baby Care Platform
                    </span>

                    <h1 class="display-5 fw-bold mb-3">
                        Find a Safe & Reliable
                        <span class="text-primary">Baby Sitter</span>
                        for Your Family
                    </h1>

                    <p class="lead text-muted mb-4">
                        SmartBabySitter helps parents find trusted babysitters, manage bookings,
                        track schedules, and review services easily from one place.
                    </p>

                    <div class="d-flex flex-wrap gap-2">
                        <a class="btn btn-primary btn-lg px-4" href="/Web/Login">Login</a>
                        <a class="btn btn-outline-primary btn-lg px-4" href="/Web/Register">Register</a>
                        <a class="btn btn-success btn-lg px-4" href="/Web/Sitters">Search Sitters</a>
                    </div>

                    <div class="row mt-4 text-center text-lg-start">
                        <div class="col-4">
                            <h4 class="fw-bold text-primary mb-0">100+</h4>
                            <small class="text-muted">Trusted Sitters</small>
                        </div>
                        <div class="col-4">
                            <h4 class="fw-bold text-success mb-0">500+</h4>
                            <small class="text-muted">Bookings</small>
                        </div>
                        <div class="col-4">
                            <h4 class="fw-bold text-warning mb-0">4.9★</h4>
                            <small class="text-muted">Parent Rating</small>
                        </div>
                    </div>
                </div>
            </div>

            

            <div class="col-lg-6">
                <div class="card border-0 shadow-lg rounded-4 overflow-hidden h-100">
                    <div>
                        
                        <ul class="list-unstyled mb-0 fs-5">
                            <img src="~/images/download (7).jpeg" class="w-100 h-100 object-fit-cover" />
                        </ul>
                    </div>
                </div>
            </div>
        </div>




        <div class="row align-items-center g-4 mb-5"> 


            <div class="col-lg-6">
                <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                    <div>

                        <ul class="list-unstyled mb-0 fs-5">
                            <img src="~/images/images.jpeg" class="w-100 h-50 object-fit-cover" />
                        </ul>

                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="pe-lg-4 ">


                    <h3 class="fw-bold mb-3">Why Choose KIDOHAVEN?</h3>
                    <ul class="list-unstyled mb-0 fs-5">
                        <li class="mb-3">✔ Easy sitter search and booking</li>
                        <li class="mb-3">✔ Verified sitter profiles</li>
                        <li class="mb-3">✔ Availability and schedule tracking</li>
                        <li class="mb-3">✔ Ratings and reviews from parents</li>
                        <li class="mb-0">✔ Secure and simple management panel</li>
                    </ul>
                </div>
            </div>


        </div>

        <div class="row g-4 mb-5">
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm rounded-4">
                    <div class="card-body p-4 text-center">
                        <div class="mb-3 fs-1">👨‍👩‍👧</div>
                        <h4 class="fw-bold">For Parents</h4>
                        <p class="text-muted mb-0">
                            Search babysitters, create bookings, manage schedules,
                            and leave reviews after service completion.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm rounded-4">
                    <div class="card-body p-4 text-center">
                        <div class="mb-3 fs-1">🧸</div>
                        <h4 class="fw-bold">For Baby Sitters</h4>
                        <p class="text-muted mb-0">
                            Manage booking requests, confirm availability,
                            complete jobs, and build trust through reviews.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm rounded-4">
                    <div class="card-body p-4 text-center">
                        <div class="mb-3 fs-1">🛡️</div>
                        <h4 class="fw-bold">For Admin</h4>
                        <p class="text-muted mb-0">
                            Monitor users, approve sitters, manage bookings,
                            payments, and overall platform activities.
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4 mb-5">
            <div class="card-body p-4 p-md-5">
                <div class="row g-4 align-items-center">
                    <div class="col-md-8">
                        <h3 class="fw-bold mb-2">How it works</h3>
                        <p class="text-muted mb-0">
                            Register an account, explore sitter profiles, send a booking request,
                            confirm your schedule, and review the experience after the job is completed.
                        </p>
                    </div>
                    <div class="col-md-4 text-md-end">
                        <a href="/Web/Sitters" class="btn btn-success btn-lg px-4">Find a Sitter</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="text-center py-4">
            <h3 class="fw-bold mb-3">Start your journey with SmartBabySitter</h3>
            <p class="text-muted mb-4">
                Safe care, easy booking, and better peace of mind for every parent.
            </p>
            <div class="d-flex justify-content-center flex-wrap gap-2">
                <a class="btn btn-primary px-4" href="/Web/Login">Get Started</a>
                <a class="btn btn-outline-dark px-4" href="/Web/Register">Create Account</a>
            </div>
        </div>

    </div>
</body>
</html>