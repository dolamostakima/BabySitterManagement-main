@{
    ViewData["Title"] = "Register";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Register - Kido Haven</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            margin: 0;
            padding: 0;
            height: 100vh;
            font-family: 'Segoe UI', sans-serif;
            position: relative;
        }

            body::before {
                content: "";
                position: absolute;
                inset: 0;
                background: url('/images/Reg.jpg') no-repeat center center;
                background-size: cover;
                z-index: -2;
            }

            body::after {
                content: "";
                position: absolute;
                inset: 0;
                background: rgba(0,0,0,0.2); /* overlay */
                z-index: -1;
            }
        .register-wrapper {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
        }

        .register-card {
            width: 100%;
            max-width: 420px;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.12);
            border: none;
            background: linear-gradient(135deg, #e0f2ff, #ffffff);
            padding: 30px;
        }

        .logo-text {
            font-size: 28px;
            font-weight: 700;
            background: linear-gradient(90deg, #0d6efd, #00c6ff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .form-control,
        .form-select {
            border-radius: 10px;
            padding: 10px 12px;
        }

            .form-control:focus,
            .form-select:focus {
                box-shadow: 0 0 0 0.15rem rgba(13,110,253,0.2);
                border-color: #86b7fe;
            }

        .btn-custom {
            width: 100%;
            border-radius: 10px;
            background: linear-gradient(90deg, #0d6efd, #00c6ff);
            border: none;
            font-weight: 600;
            color: white;
            padding: 10px;
        }

            .btn-custom:hover {
                opacity: 0.92;
                color: white;
            }

        .small-link {
            font-size: 14px;
            color: #6c757d;
            text-decoration: none;
        }

            .small-link:hover {
                text-decoration: underline;
            }

        .logo-img {
            object-fit: contain;
        }
    </style>
</head>
<body>

    <div class="register-wrapper">
        <div class="register-card">

            <div class="text-center mb-4">
                <a href="/">
                    <img src="/images/logo__2_-removebg-preview.png" width="200" />
                </a>
                <div class="logo-text">KidoHaven</div>
                <p class="text-muted mt-2 mb-0">Create your account to get started</p>
            </div>

            <div id="msg"></div>

            <div class="mb-3">
                <label for="role" class="form-label fw-semibold">Choose Your Role</label>
                <select id="role" class="form-select">
                    <option value="">-- Select Role --</option>
                    <option value="Parent">Parent</option>
                    <option value="BabySitter">BabySitter</option>
                </select>
            </div>

            <button id="btnContinue" class="btn btn-custom mb-3">Continue</button>

            <div class="text-center">
                <a href="/Web/Login" class="small-link">
                    Already have an account? <b>Log in</b>
                </a>
            </div>

        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script>
        function showMsg(selector, msg, type) {
            const cls = type === "ok" ? "alert-success" : "alert-danger";
            $(selector).html(`<div class="alert ${cls}">${msg}</div>`);
        }

        function goToSelectedRole() {
            const role = $("#role").val();

            if (!role) {
                showMsg("#msg", "Please select a role first.", "err");
                return;
            }

            if (role === "Parent") {
                window.location.href = "/Web/RegisterParent";
            }
            else if (role === "BabySitter") {
                window.location.href = "/Web/RegisterBabysitterType";
            }
        }

        $("#btnContinue").click(function () {
            goToSelectedRole();
        });

        $("#role").change(function () {
            $("#msg").html("");
        });
    </script>
</body>
</html>



