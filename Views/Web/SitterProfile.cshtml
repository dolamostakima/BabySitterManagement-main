@{
    ViewData["Title"] = "My Sitter Profile";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>

    body {
        background: #f7f8fc;
    }

    .profile-card {
        background: #fff;
        border-radius: 15px;
        padding: 30px;
        box-shadow: 0 2px 15px rgba(0,0,0,.08);
    }

    .profile-img {
        width: 170px;
        height: 170px;
        border-radius: 50%;
        object-fit: cover;
        border: 5px solid #e9ecef;
        cursor: pointer;
        transition: .3s;
    }

        .profile-img:hover {
            transform: scale(1.03);
        }

    .section-title {
        font-weight: 600;
        margin-bottom: 20px;
    }

    .card {
        border: none;
        border-radius: 12px;
        box-shadow: 0 2px 10px rgba(0,0,0,.08);
    }
</style>

<h3 class="mb-4">My Sitter Profile</h3>

<div id="msg"></div>

<div class="profile-card">

    <div class="text-center mb-4">

        <label for="image">

            <img id="profileImage"
                 src="/images/default-user.png"
                 class="profile-img" />

        </label>

        <input type="file"
               id="image"
               accept="image/*"
               hidden />

        <div class="mt-2 text-muted">
            Click the picture to change profile photo
        </div>

    </div>


    <h5 class="section-title">
        Personal Information
    </h5>

    <div class="row">

        <div class="col-md-6 mb-3">

            <label>Full Name</label>

            <input id="fullName"
                   class="form-control">

        </div>

        <div class="col-md-6 mb-3">

            <label>Email</label>

            <input id="email"
                   class="form-control">

        </div>

        <div class="col-md-6 mb-3">

            <label>Mobile Number</label>

            <input id="mobile"
                   class="form-control">

        </div>

        <div class="col-md-6 mb-3">

            <label>NID Number</label>

            <input id="nid"
                   class="form-control">

        </div>

        <div class="col-md-6 mb-3">

            <label>Gender</label>

            <select id="gender"
                    class="form-select">

                <option value="">Select Gender</option>

                <option>Male</option>

                <option>Female</option>

            </select>

        </div>

        <div class="col-md-6 mb-3">

            <label>Date of Birth</label>

            <input type="date"
                   id="dob"
                   class="form-control">

        </div>

        <div class="col-12 mb-3">

            <label>Address</label>

            <textarea id="address"
                      rows="2"
                      class="form-control"></textarea>

        </div>

    </div>

    <hr />

    <h5 class="section-title">
        Professional Information
    </h5>

    <div class="mb-3">

        <label>Skills (Comma Separated)</label>

        <input id="skills"
               class="form-control"
               placeholder="Cooking, Child Care, First Aid">

    </div>

    <div class="mb-3">

        <label>Skills Description</label>

        <textarea id="skillsText"
                  rows="3"
                  class="form-control"></textarea>

    </div>

 

    <div class="row">

        <div class="col-md-4 mb-3">

            <label>Experience (Years)</label>

            <input type="number"
                   id="exp"
                   class="form-control">

        </div>

        <div class="col-md-4 mb-3">

            <label>Hourly Rate</label>

            <input type="number"
                   id="rate"
                   class="form-control">

        </div>

        <div class="col-md-4 mb-3">

            <label>Available Location</label>

            <input id="loc"
                   class="form-control">

        </div>

    </div>

    <div class="text-end">

        <button id="btnSave"
                class="btn btn-success px-4">

            Save Profile

        </button>

    </div>

</div>


<div class="row mt-4">

    <div class="col-md-6">

        <div class="card p-3">

            <h5>
                My Skills
            </h5>

            <ul id="skillsList"></ul>

        </div>

    </div>

    <div class="col-md-6">

        <div class="card p-3">

            <h5>
                My Availability
            </h5>

            <div id="avList"></div>

        </div>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

@section Scripts {
    <script>

        // ================= IMAGE PREVIEW =================

        $("#profileImage").click(function () {
            $("#image").click();
        });

        $("#image").change(function () {

            var file = this.files[0];

            if (file) {

                var reader = new FileReader();

                reader.onload = function (e) {
                    $("#profileImage").attr("src", e.target.result);
                }

                reader.readAsDataURL(file);
            }
        });

        // ================= TOKEN =================

        function getToken() {
            return (localStorage.getItem("jwt_token") || "").replace(/^"|"$/g, "");
        }

        function showOk(msg) {
            $("#msg").html(`<div class="alert alert-success">${msg}</div>`);
        }

        function showErr(msg) {
            $("#msg").html(`<div class="alert alert-danger">${msg}</div>`);
        }

        function formatDay(d) {
            if (d == null) return "";
            const days = ["Sunday","Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"];
            return days[d];
        }

        function formatTime(t) {
            if (!t) return "";
            return t.substring(0,5);
        }

        // ================= LOAD PROFILE =================

        function loadMyProfile() {

            $.ajax({
                url: "/api/SitterProfile/me/profile",
                method: "GET",
                headers: {
                    Authorization: `Bearer ${getToken()}`
                }
            })
            .done(function (p) {

                if (!p) return;

                if (p.photoUrl) {
                    $("#profileImage").attr("src", p.photoUrl);
                }

        // User Information
                $("#fullName").val(p.fullName || "");
        $("#email").val(p.email || "");
        $("#mobile").val(p.phoneNo || "");

        $("#nid").val(p.nidNo || "");
        $("#gender").val(p.gender || "");
        $("#dob").val(p.dateOfBirth ? p.dateOfBirth.substring(0,10) : "");
        $("#address").val(p.address || "");
        // Profile Information
        $("#skillsText").val(p.skillsText || "");
        $("#skills").val((p.skills || []).join(", "));
        $("#exp").val(p.experienceYears || "");
        $("#rate").val(p.hourlyRate || "");
        $("#loc").val(p.locationText || "");

                // Skill List
                $("#skillsList").empty();

                if (p.skills) {

                    p.skills.forEach(function (s) {
                        $("#skillsList").append(`<li>${s}</li>`);
                    });

                }

                // Availability

                if (!p.availabilities || p.availabilities.length == 0) {

                    $("#avList").html("<p>No Availability</p>");
                }
                else {

                    var html = `<table class="table table-bordered">
                            <thead>
                            <tr>
                            <th>Day</th>
                            <th>Date</th>
                            <th>Time</th>
                            <th>Status</th>
                            </tr>
                            </thead><tbody>`;

                    p.availabilities.forEach(function (a) {

                        html += `
                        <tr>
                            <td>${formatDay(a.day)}</td>
                            <td>${a.date ? a.date.substring(0,10) : ""}</td>
                            <td>${formatTime(a.startTime)} - ${formatTime(a.endTime)}</td>
                            <td>${a.isAvailable ? "Available" : "Unavailable"}</td>
                        </tr>`;
                    });

                    html += "</tbody></table>";

                    $("#avList").html(html);

                }

            })
            .fail(function () {
                showErr("Load Failed");
            });

        }

        // ================= SAVE PROFILE =================

        $("#btnSave").click(function () {

            var formData = new FormData();

                    // User Information
        formData.append("FullName", $("#fullName").val());
        formData.append("Email", $("#email").val());
        formData.append("PhoneNo", $("#mobile").val());
        formData.append("NidNo", $("#nid").val());
        formData.append("Gender", $("#gender").val());
        formData.append("DateOfBirth", $("#dob").val());
        formData.append("Address", $("#address").val());

        // Profile Information
        formData.append("SkillsText", $("#skillsText").val());
        formData.append("ExperienceYears", $("#exp").val());
        formData.append("HourlyRate", $("#rate").val());
        formData.append("LocationText", $("#loc").val());

            var skills = $("#skills").val().split(",");

            skills.forEach(function (s) {

                if (s.trim() != "")
                    formData.append("Skills", s.trim());

            });

            var file = $("#image")[0].files[0];

            if (file) {
                formData.append("Image", file);
            }

            $.ajax({

                url: "/api/SitterProfile",
                method: "POST",
                headers: {
                    Authorization: `Bearer ${getToken()}`
                },
                data: formData,
                processData: false,
                contentType: false

            })
                   .done(function (r) {

            Swal.fire({
                icon: "success",
                title: "Profile Updated",
                text: " saved successfully.",
                timer: 1800,
                showConfirmButton: false
            });

            loadMyProfile();

        })
            .fail(function (xhr) {

                showErr(xhr.responseText);

            });

        });

        // ================= PAGE LOAD =================

        $(document).ready(function () {

            loadMyProfile();

        });

    </script>
}






































