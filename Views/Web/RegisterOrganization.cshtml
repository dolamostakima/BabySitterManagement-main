@{
    ViewData["Title"] = "Organization Register";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
    body {
        background: linear-gradient(135deg, #F9E3DF, #F3C6C0);
        margin: 0;
    }

    .page-wrapper {
        height: auto;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .register-card {
        width: auto;
        min-width: 800px;
        border: none;
        border-radius: 12px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.08);
        padding: 20px;
    }

    label {
        font-size: 18px;
        margin-bottom: 2px;
    }

    .form-control {
        border-radius: 8px;
        padding: 7px 10px;
        font-size: 14px;
    }

    .btn {
        padding: 8px;
        font-size: 14px;
    }
</style>

<div class="page-wrapper">
    <div class="card register-card p-4">

        <!-- Logo + Title -->
        <div class="text-center mb-3">
            <a href="/">
                <img src="/images/logo__2_-removebg-preview.png" width="200" />
            </a>
            <h5 class="mb-0">Organization Registration</h5>
            <small class="text-muted">Send request for approval</small>
        </div>

        <form id="registerForm">

            <!-- Organization Info -->
            <div class="mb-2">
                <label>Organization Name</label>
                <input type="text" name="OrgName" class="form-control" placeholder="e.g. Care Home Ltd." required>
            </div>

            <div class="mb-2">
                <label>Trade License</label>
                <input type="text" name="RegNo" class="form-control" placeholder="e.g. TL-12345678" required>
            </div>

            <div class="mb-2">
                <label>Email</label>
                <input type="email" name="Email" class="form-control" placeholder="e.g. org@gmail.com" required>
            </div>

            <div class="mb-2">
                <label>Phone No</label>
                <input type="text" name="Phone" class="form-control" placeholder="e.g. 017XXXXXXXX" required>
            </div>

            <!-- Address Section -->
            <h6 class="mt-3">Address Details</h6>

            <div class="row">
                <div class="col-md-6 mb-2">
                    <label>House</label>
                    <input type="text" name="House" class="form-control" placeholder="e.g. 12" required>
                </div>

                <div class="col-md-6 mb-2">
                    <label>Road</label>
                    <input type="text" name="Road" class="form-control" placeholder="e.g. 5" required>
                </div>

                <div class="col-md-6 mb-2">
                    <label>Block / Area</label>
                    <input type="text" name="Area" class="form-control" placeholder="e.g. Banasree" required>
                </div>

                <div class="col-md-6 mb-2">
                    <label>District</label>
                    <input type="text" name="District" class="form-control" placeholder="e.g. Dhaka" required>
                </div>

                <div class="col-md-6 mb-2">
                    <label>Zip Code</label>
                    <input type="text" name="Zip" class="form-control" placeholder="e.g. 1219" required>
                </div>
            </div>

            <!-- Buttons -->
            <div class="d-flex justify-content-between mt-3">
                <button type="submit" class="btn btn-dark">
                    Request to Register
                </button>

                <button type="button" class="btn btn-outline-secondary" onclick="history.back()">
                    Back ⮜
                </button>
            </div>

        </form>

    </div>
</div>
<script>
    async function submitForm(event) {
        event.preventDefault(); // form reload বন্ধ করবে

        const data = {
            orgName: document.getElementById("OrgName").value,
            regNo: document.getElementById("RegNo").value,
            email: document.getElementById("Email").value,
            phone: document.getElementById("Phone").value,
            house: document.getElementById("House").value,
            road: document.getElementById("Road").value,
            area: document.getElementById("Area").value,
            district: document.getElementById("District").value,
            zip: document.getElementById("Zip").value
        };

        const response = await fetch('/api/organizations', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(data)
        });

        if (response.ok) {
            alert("Request submitted successfully");
        } else {
            alert("Error occurred");
        }
    }
</script>