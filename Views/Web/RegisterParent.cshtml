@{
    ViewData["Title"] = "Parent Register";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Parent Register</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            background: linear-gradient(135deg, #F9E3DF, #F3C6C0);
            font-family: 'Segoe UI', sans-serif;
        }

        .page-wrapper {
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .card-box {
            width: 100%;
            max-width: 850px;
            border-radius: 16px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.08);
            padding: 25px;
            background: #fff;
        }

        .form-control, .form-select {
            border-radius: 8px;
            padding: 10px;
        }

        label {
            font-weight: 500;
            margin-bottom: 5px;
        }

        .btn-create {
            background: #212529;
            color: #fff;
        }

            .btn-create:hover {
                background: #111;
            }

        .error-text {
            color: red;
            font-size: 12px;
            display: none;
        }
    </style>
</head>
<body>

    <div class="page-wrapper">
        <div class="card-box">

            <div class="text-center mb-4">
                <a href="/">
                    <img src="/images/logo__2_-removebg-preview.png" width="200" />
                </a>
                <h4>Parent Registration</h4>
            </div>

            <div id="msg"></div>

            <form id="registerForm">

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label>Full Name</label>
                        <input type="text" id="fullName" class="form-control" required>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>NID No</label>
                        <input type="text" id="nidNo" class="form-control" required>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Gender</label>
                        <select id="gender" class="form-select" required>
                            <option value="">Select</option>
                            <option>Male</option>
                            <option>Female</option>
                            <option>Other</option>
                        </select>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Date of Birth</label>
                        <input type="date" id="dob" class="form-control" required>
                    </div>

                    <div class="col-12 mb-3">
                        <label>Address</label>
                        <textarea id="address" class="form-control" rows="2" required></textarea>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Email</label>
                        <input type="email" id="email" class="form-control" required>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Phone No</label>
                        <input type="text" id="phoneNo" class="form-control" required>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Password</label>
                        <input type="password" id="password" class="form-control" required>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Confirm Password</label>
                        <input type="password" id="confirmPassword" class="form-control" required>
                        <div id="errorMsg" class="error-text">Password mismatch</div>
                    </div>
                </div>

                <div class="d-flex justify-content-between">
                    <button type="submit" class="btn btn-create">
                        Create Account
                    </button>

                    <button type="button" class="btn btn-outline-secondary" onclick="history.back()">
                        Back ⮜
                    </button>
                </div>

            </form>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    <script>
        const API_BASE = ""; // set your base url

        function showMsg(selector, msg, type) {
            const cls = type === "ok" ? "alert-success" : "alert-danger";
            $(selector).html(`<div class="alert ${cls}">${msg}</div>`);
        }

        $("#registerForm").submit(function (e) {
            e.preventDefault();

            const password = $("#password").val();
            const confirmPassword = $("#confirmPassword").val();

            if (password !== confirmPassword) {
                $("#errorMsg").show();
                return;
            } else {
                $("#errorMsg").hide();
            }

            if (password.length < 6) {
                showMsg("#msg", "Password must be at least 6 characters", "err");
                return;
            }

            const data = {
                fullName: $("#fullName").val().trim(),
                nidNo: $("#nidNo").val().trim(),
                gender: $("#gender").val(),
                dateOfBirth: $("#dob").val(),
                address: $("#address").val().trim(),
                email: $("#email").val().trim(),
                phoneNo: $("#phoneNo").val().trim(),
                password: password,

                // 🔥 API alignment
                role: "Parent",
                type: 1,
                experience: ""
            };

            $.ajax({
                url: API_BASE + "/api/auth/register",
                method: "POST",
                contentType: "application/json",
                data: JSON.stringify(data),

                success: function (res) {
                    localStorage.setItem("token", res.token);
                    localStorage.setItem("user_roles", JSON.stringify(res.roles));

                    showMsg("#msg", "✅ Registration successful", "ok");

                    setTimeout(() => {
                        window.location.href = "/Web/Login";
                    }, 800);
                },

                error: function (xhr) {
                    showMsg("#msg", xhr.responseText || "Registration failed", "err");
                }
            });
        });
    </script>

</body>
</html>