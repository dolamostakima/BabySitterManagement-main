@{
    ViewData["Title"] = "Sitter Register";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
    body {
        background: linear-gradient(135deg, #F9E3DF, #F3C6C0);
        margin: 0;
    }

    .page-wrapper {
        height: auto;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .register-card {
        width: auto;
        min-width: 800px;
        border: none;
        border-radius: 12px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.08);
        padding: 20px;
    }

    label {
        font-size: 18px;
        margin-bottom: 2px;
    }

    .form-control, .form-select {
        border-radius: 8px;
        padding: 7px 10px;
        font-size: 14px;
    }

    .btn {
        padding: 8px;
        font-size: 14px;
    }

    .error-text {
        color: red;
        font-size: 12px;
        display: none;
    }
</style>

<div class="page-wrapper">
    <div class="card register-card p-4">

        <!-- Logo + Title -->
        <div class="text-center mb-3">
            <a href="/">
                <img src="/images/logo__2_-removebg-preview.png" width="200" />
            </a>
            <h5 class="mb-0">Individual Sitter Registration</h5>
            <small class="text-muted">Create your sitter account</small>
        </div>

        <form id="registerForm">

            <div class="row">
                <div class="col-md-6 mb-2">
                    <label>Full Name</label>
                    <input type="text" id="fullName" class="form-control" required>
                </div>

                <div class="col-md-6 mb-2">
                    <label>NID No</label>
                    <input type="text" id="nidNo" class="form-control" required>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-2">
                    <label>Gender</label>
                    <select id="gender" class="form-select" required>
                        <option value="">Select</option>
                        <option>Male</option>
                        <option>Female</option>
                        <option>Other</option>
                    </select>
                </div>

                <div class="col-md-6 mb-2">
                    <label>Date of Birth</label>
                    <input type="date" id="dateOfBirth" class="form-control" required>
                </div>
            </div>

            <div class="mb-2">
                <label>Address</label>
                <textarea id="address" class="form-control" required></textarea>
            </div>

            <div class="row">
                <div class="col-md-6 mb-2">
                    <label>Email</label>
                    <input type="email" id="email" class="form-control" required>
                </div>

                <div class="col-md-6 mb-2">
                    <label>Phone No</label>
                    <input type="text" id="phoneNo" class="form-control" required>
                </div>
            </div>

            <div class="mb-2">
                <label>Experience</label>
                <input type="text" id="experience" class="form-control" required>
            </div>

            <div class="row">
                <div class="col-md-6 mb-2">
                    <label>Password</label>
                    <input type="password" id="password" class="form-control" required>
                </div>

                <div class="col-md-6 mb-2">
                    <label>Confirm Password</label>
                    <input type="password" id="confirmPassword" class="form-control" required>
                    <div id="errorMsg" class="error-text">Password mismatch!</div>
                </div>
            </div>

            <div class="d-flex justify-content-between">
                <button type="submit" class="btn btn-dark">
                    Register
                </button>

                <button type="button" class="btn btn-outline-secondary" onclick="history.back()">
                    Back ⮜
                </button>
            </div>
           

        </form>

    </div>
</div>

@section Scripts {
    <script>
       $("#registerForm").submit(function (e) {
            e.preventDefault();

            const password = $("#password").val();
            const confirmPassword = $("#confirmPassword").val();

            if (password !== confirmPassword) {
                $("#errorMsg").show();
                return;
            } else {
                $("#errorMsg").hide();
            }

            const data = {
                fullName: $("#fullName").val(),
                email: $("#email").val(),
                password: password,
                role: "BabySitter",

                nidNo: $("#nidNo").val(),
                gender: $("#gender").val(),
                dateOfBirth: $("#dateOfBirth").val(),
                address: $("#address").val(),
                phoneNo: $("#phoneNo").val(),
                experience: $("#experience").val(),
                type: 2
            };

            $.ajax({
                url: API_BASE + "/api/auth/register",
                method: "POST",
                contentType: "application/json",
                data: JSON.stringify(data),

                success: function (res) {
                    localStorage.setItem("token", res.token);
                    localStorage.setItem("user_roles", JSON.stringify(res.roles));

                    alert("✅ Registration Successful");
                    window.location.href = "/Web/Sitters";
                },

                error: function (xhr) {
                    alert("❌ " + (xhr.responseText || "Registration failed"));
                }
            });
        });
    </script>
}