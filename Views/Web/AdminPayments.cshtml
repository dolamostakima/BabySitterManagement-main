@{
    ViewData["Title"] = "Admin - Payments";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h3> Payments</h3>

<div class="card p-3 mb-3">
    <div class="row g-2 align-items-end">

        <div class="col-md-3">
            <label>Status</label>
            <select id="status" class="form-select">
                <option value="">All</option>
                <option>Pending</option>
                <option>Paid</option>
                <option>Refunded</option>
            </select>
        </div>

        <div class="col-md-3">
            <label>From</label>
            <input id="from" type="date" class="form-control" />
        </div>

        <div class="col-md-3">
            <label>To</label>
            <input id="to" type="date" class="form-control" />
        </div>

        <div class="col-md-3 d-flex gap-2">

            <button id="btnLoad" class="btn btn-primary w-50">🔍︎</button>

            <button id="btnDownload" class="btn btn-primary w-50">🡻</button>
        </div>

    </div>
</div>

<div id="msg"></div>
<div id="list"></div>

@section Scripts {
    <script>
        function load() {
            const st = $("#status").val();
            const url = "/api/admin/payments" + (st ? ("?status=" + st) : "");

            $.get(url)
                .done(function(items) {
                    if (!items.length) {
                        $("#list").html(`<div class="alert alert-warning">No payments.</div>`);
                        return;
                    }

                    let html = `<table class="table table-bordered">
                             <thead>
        <tr>
            <th>Payment ID</th>
            <th>Booking ID</th>
            <th>Parent</th>
            <th>Sitter</th>
            <th>Amount</th>
            <th>Method</th>
            <th>Transaction ID</th>
            <th>Status</th>
            <th>Created</th>
            <th>Action</th>
        </tr>
        </thead>
        <tbody>`;

                    items.forEach(p => {
                               html += `<tr>
            <td>${p.id}</td>
            <td>${p.bookingId}</td>
            <td>${p.parentName}</td>
            <td>${p.sitterName}</td>
            <td>${p.amount}</td>
            <td>${p.method}</td>
            <td>${p.transactionId || "-"}</td>
            <td>${p.statusName}</td>
            <td>${(p.createdAt || "").substring(0,10)}</td>
            <td>
                ${
                    p.statusName === "Pending"
                    ? `
                        <button class="btn btn-success btn-sm approve"
                                data-id="${p.id}">
                            Approve
                        </button>

                        <button class="btn btn-danger btn-sm reject"
                                data-id="${p.id}">
                            Reject
                        </button>
                      `
                    : "-"
                }
            </td>
        </tr>`;
                    });

                    html += `</tbody></table>`;
                    $("#list").html(html);
                })
                .fail(function(xhr) {
                    showMsg("#msg", xhr.responseText || "Load failed", "err");
                });
        }

        $("#btnLoad").click(load);
        load();
                $("#btnDownload").click(function () {

            let table = document.querySelector("table");
            if (!table) {
                alert("No data to download");
                return;
            }

            let rows = table.querySelectorAll("tr");
            let csv = [];

            rows.forEach(row => {
                let cols = row.querySelectorAll("th, td");
                let rowData = [];
                cols.forEach(col => {
                    rowData.push(col.innerText);
                });
                csv.push(rowData.join(","));
            });

            let csvContent = "data:text/csv;charset=utf-8," + csv.join("\n");

            let encodedUri = encodeURI(csvContent);
            let link = document.createElement("a");
            link.setAttribute("href", encodedUri);
            link.setAttribute("download", "payments.csv");
            document.body.appendChild(link);

            link.click();
            document.body.removeChild(link);
        });

                $(document).on("click", ".approve", function () {

            const id = $(this).data("id");

            const token = (localStorage.getItem("jwt_token") || "").replace(/^"|"$/g, "");

            $.ajax({
                url: "/api/payments/" + id,
                method: "PUT",
                headers: {
                    Authorization: `Bearer ${token}`
                },
                contentType: "application/json",
                data: JSON.stringify({
                    transactionId: null,
                    status: 2
                }),
                success: function () {
                    alert("Payment Approved");
                    load();
                },
                error: function (xhr) {
                    alert(xhr.responseText || "Failed");
                }
            });

        });

        $(document).on("click", ".reject", function () {

            const id = $(this).data("id");

            const token = (localStorage.getItem("jwt_token") || "").replace(/^"|"$/g, "");

            $.ajax({
                url: "/api/payments/" + id,
                method: "PUT",
                headers: {
                    Authorization: `Bearer ${token}`
                },
                contentType: "application/json",
                data: JSON.stringify({
                    transactionId: null,
                    status: 3
                }),
                success: function () {
                    alert("Payment Rejected");
                    load();
                },
                error: function (xhr) {
                    alert(xhr.responseText || "Failed");
                }
            });

        });

    </script>
}